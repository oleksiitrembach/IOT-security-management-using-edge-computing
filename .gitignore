# ===========================================================================
# .gitignore — IoT Edge Security Testbed
# ===========================================================================

# --- Experiment data (commit selected results intentionally with git add -f) ---
data/*
!data/.gitkeep

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# --- Thesis document (private — not part of the codebase) ---
*.docx
*.pptx
*.xlsx

# --- TLS certificates (generated, contain private keys) ---
certs/

# --- Environment (may contain secrets) ---
.env

# --- IDE ---
.vscode/
.idea/
*.swp
*~

# --- Docker ---
docker-compose.override.yml

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log
*.sqlite
