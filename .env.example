# ===========================================================================
# .env.example — domyślne wartości zmiennych środowiskowych
# ===========================================================================
# Skopiuj do .env i dostosuj:  cp .env.example .env
# Docker Compose automatycznie wczyta .env.
# ===========================================================================

# --- Lokalizacja detekcji (PB1/H1) ---
# edge    = detekcja na węźle brzegowym (wariant brzegowy)
# central = detekcja na systemie centralnym (wariant scentralizowany)
DETECTION_LOCATION=edge

# --- Scenariusz (Tabela 3) ---
# normal  = S1: tylko ruch normalny (FPR, zasoby)
# mixed   = S2: mix anomalii 5% (skalowalność)
# flood   = S3: nadmierna częstotliwość (czas detekcji, czułość)
# payload = S4: anomalia ładunku (czas detekcji, precyzja)
# value   = anomalia wartości k-sigma (czułość reguły statystycznej)
SCENARIO=mixed

# --- Czas przebiegu [s] ---
DURATION=120

# --- Parametry symulatorów ---
RATE=5                  # komunikaty/s na urządzenie (ruch normalny)
ANOMALY_RATE=0.05       # prawdopodobieństwo anomalii per komunikat
MU=25.0                 # średnia wartości sensorowej
SIGMA=1.5               # odchylenie standardowe wartości sensorowej
FLOOD_BURST=40          # liczba komunikatów w jednym burście flood
PAYLOAD_BYTES=1024      # rozmiar padded payload [B] w anomalii payload

# --- Parametry detektora ---
FREQ_THRESHOLD=20       # max komunikatów w oknie 1s zanim alarm flood
MAX_PAYLOAD=512         # max rozmiar ładunku [B] zanim alarm payload
WARMUP=30               # min obserwacji przed włączeniem reguły k-sigma
K_SIGMA=4.0             # mnożnik odchylenia standardowego

# --- Opóźnienie sieciowe (wariant central) ---
LATENCY=60ms            # emulacja RTT do chmury przez toxiproxy (kierunkowo broker->central)

# --- Zbieranie statystyk zasobów ---
STATS_INTERVAL=0.5      # interwał próbkowania CPU/RAM [s]

# --- Skalowanie urządzeń (PB5) ---
DEVICE_COUNT=1          # liczba symulatorów IoT
COUNTS="1 5 10 20"      # liczba urządzeń dla skryptu skalowalności

# --- Parametry awarii (S7) ---
KILL_AT=60              # po ilu sekundach ubić węzeł
DOWN=30                 # ile sekund węzeł ma być niedostępny
